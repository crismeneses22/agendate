# Local development only. Do not upload this file as production .env.
AGENDATE_ENV=local
AGENDATE_APP_URL=http://localhost/agendate
AGENDATE_ALLOWED_ORIGINS=http://localhost:8081
AGENDATE_DEV_SKIP_EMAIL_VERIFICATION=true

AGENDATE_DB_NAME=agendate
AGENDATE_DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock
AGENDATE_DB_HOST=127.0.0.1
AGENDATE_DB_PORT=3306
AGENDATE_DB_USER=root
AGENDATE_DB_PASS=

AGENDATE_ADMIN_EMAIL=admin@agendate.app
AGENDATE_ADMIN_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
AGENDATE_ALLOW_INIT=false
AGENDATE_INIT_TOKEN=CHANGE_THIS_TO_A_LONG_RANDOM_INIT_TOKEN

AGENDATE_MAIL_FROM=
AGENDATE_MAIL_FROM_NAME=agendate
AGENDATE_SMTP_HOST=
AGENDATE_SMTP_PORT=587
AGENDATE_SMTP_USER=
AGENDATE_SMTP_PASS=

VITE_PORT=8081
VITE_BACKEND_ORIGIN_DEV=http://localhost/agendate
VITE_BACKEND_ORIGIN=http://187.127.1.112:8081
